<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->

<labwc_config>

  <theme>
    <name>Clearlooks-3.4</name>
    <cornerRadius>8</cornerRadius>
    <font name="sans" size="10" />
  </theme>

  <keyboard>
    <default />
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="foot" />
    </keybind>
    <!--
      Remove a previously defined keybind
      A shorter alternative is <keybind key="W-F4" />
    -->
    <keybind key="W-F4">
      <action name="None" />
    </keybind>

    <!-- print screen --> 
    <keybind key="Print">
     <action name="Execute" command='bash -c "grim ~/Pictures/$(date +%Y-%m-%d_%H-%m-%s).png"' />
    </keybind>

    <keybind key="S-Print">
     <action name="Execute" command='bash -c "grim -g \"$(slurp)\" ~/Pictures/$(date +%Y-%m-%d_%H-%m-%s).png"' />
    </keybind>
    
    <keybind key="W-d">
     <action name="Execute" command="wofi --show drun --prompt 'Search Apps...'" />
    </keybind>
    
    <keybind key="W-l">
     <action name="Execute" command="swaylock -i /home/digiwizkid/wallpapers/saver.jpg --indicator-radius 100 --inside-color 00000088 --ring-color 00ffffff --key-hl-color ff00ffff"/>
    </keybind>

    <keybind key="W-h">
      <action name="Execute" command="clipman pick --tool wofi --tool-args='--dmenu --prompt Clipboard'" />
    </keybind>

  </keyboard>

  <mouse>
    <default />
    <!-- Show a custom menu on desktop right click -->
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="some-custom-menu" />
      </mousebind>
    </context>
  </mouse>

</labwc_config>
